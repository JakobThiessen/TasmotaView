{
  "name": "tasmotaview",
  "version": "1.0.0",
  "description": "TasmotaView - Tasmota Device Manager for local networks",
  "private": true,
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "build": "npm run build --prefix frontend",
    "start": "npm start --prefix backend",
    "electron:dev": "concurrently -n backend,frontend,electron -c blue,green,yellow \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\" \"wait-on http://localhost:5173 http://localhost:3001/api/settings && electron .\"",
    "electron:build": "npm run build --prefix frontend && electron-builder --win",
    "electron:build:portable": "npm run build --prefix frontend && electron-builder --win portable"
  },
  "build": {
    "appId": "com.tasmotaview.app",
    "productName": "TasmotaView",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/data",
        "to": "backend-data"
      },
      {
        "from": "frontend/dist",
        "to": "frontend-dist"
      },
      {
        "from": "backend/src",
        "to": "backend/src"
      },
      {
        "from": "backend/node_modules",
        "to": "backend/node_modules"
      },
      {
        "from": "backend/package.json",
        "to": "backend/package.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "TasmotaView-Portable-${version}.exe"
    }
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "wait-on": "^9.0.4"
  }
}
